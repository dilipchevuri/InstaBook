# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini API — free tier, no billing needed (aistudio.google.com/apikey)
GEMINI_API_KEY=

# Your deployed site URL, no trailing slash (fill in AFTER first Vercel deploy)
NEXT_PUBLIC_SITE_URL=

# A random long string you make up yourself — protects /api/cron/daily from strangers
CRON_SECRET=

# Instagram Graph API (see SETUP_GUIDE.md — this is the fiddly part)
IG_BUSINESS_ID=
IG_ACCESS_TOKEN=
